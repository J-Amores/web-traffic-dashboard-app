# Neon Postgres connection (provisioned by the Vercel-Neon integration).
# Locally: `vercel env pull .env.local` writes these for you — do NOT commit .env.local.

# Pooled string used by the app at runtime.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Unpooled (direct) string — preferred for migrations / DDL (npm run migrate).
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require
